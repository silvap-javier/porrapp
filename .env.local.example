# Copia este archivo a .env.local y rellena los valores reales.

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# App URL (usado en /auth/callback y en los enlaces de invitación a ligas)
NEXT_PUBLIC_APP_URL=

# Notificaciones push (Web Push / VAPID). Genera un par con:
#   npx web-push generate-vapid-keys
# La pública puede ser NEXT_PUBLIC_; la privada es secreta (solo servidor).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-email@dominio.com
